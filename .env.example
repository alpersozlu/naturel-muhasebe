# DocuFlow TR — Environment Variables Template
# .env.local olarak kopyala ve gerçek değerlerle doldur (asla commit etme!)

# ──────────────────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings → API → service_role (SADECE backend, NEXT_PUBLIC_ koyma!)
SUPABASE_SERVICE_ROLE_KEY=

# Project Settings → Database → Connection string
# Pooled (transaction mode) — uygulamada bunu kullan
DATABASE_URL=postgresql://postgres:[password]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection (migration için)
DIRECT_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ──────────────────────────────────────────────────────────
# Anthropic (OCR)
# ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ──────────────────────────────────────────────────────────
# Cron / Background jobs
# ──────────────────────────────────────────────────────────
# Vercel Cron endpoint'lerini koruyan secret. Random string üret.
CRON_SECRET=

# ──────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEFAULT_LOCALE=tr
