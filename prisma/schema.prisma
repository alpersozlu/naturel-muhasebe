// DocuFlow TR — Prisma Schema (draft, Aşama 1 planlama)
// Single-tenant. Soft delete (deleted_at) çoğu tabloda var.
// RLS politikaları Supabase migration SQL'lerinde tanımlanacak (Aşama 2).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Pooled (transaction mode) — uygulama runtime
  directUrl = env("DIRECT_URL") // Direct connection — migration için
}

// ─────────────────────────────────────────────────────────────
// ENUM'lar
// ─────────────────────────────────────────────────────────────

enum UserRole {
  admin
  store_manager
  cashier
  sales_rep
}

enum UploadType {
  bank_receipt
  pos_slip
  store_summary
  expense
  cash_advance
  z_report
  dealer_daily_report // Mavi SAP / Derimod Nebim — bayi gün sonu raporu (xlsx)
}

enum UploadStatus {
  pending // OCR çalışmadı
  processing
  parsed // OCR bitti, kullanıcı onayı bekliyor
  confirmed // Kullanıcı onayladı
  failed // OCR başarısız
}

enum DailyRecordStatus {
  draft // Yüklemeler başladı, henüz tamamlanmadı
  pending // Tüm zorunlu yüklemeler tamam, admin onayı bekliyor
  approved // Admin onayladı
  locked // Kilitli, store_manager değişiklik yapamaz
}

enum VerificationStatus {
  match
  mismatch
  manual_override
}

enum Currency {
  TRY
  USD
  EUR
  GBP
}

enum ExpenseCategory {
  rent // Kira
  electricity // Elektrik
  water // Su
  internet // İnternet
  stationery // Kırtasiye
  cleaning // Temizlik
  maintenance // Bakım
  salary // Maaş
  bonus // Prim/avans
  supplies // Sarf malzeme
  food // Yemek
  marketing // Pazarlama
  other // Diğer
}

enum BudgetScope {
  total // Tüm kategorilerin toplamı
  category // Belirli bir kategoriye sınır
}

enum BudgetMode {
  amount // Sabit TRY tutarı
  ratio // Ciroya kıyasla yüzde (örn 15 = %15)
}

enum BudgetPeriod {
  monthly // Her ay sıfırlanır
  yearly // Her yıl sıfırlanır
  custom // İki tarih aralığı (period_start ↔ period_end)
}

// ─────────────────────────────────────────────────────────────
// AUTH & ORGANIZATION
// ─────────────────────────────────────────────────────────────

model User {
  id         String    @id @default(uuid()) // Supabase auth.users.id ile aynı
  email      String    @unique
  full_name  String?
  role       UserRole  @default(cashier)
  // Devre dışı bırakma (geri alınabilir): false = giriş kapalı, listede "Pasif"
  // görünür ama silinmemiştir (deleted_at ile karıştırma).
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  // Soft delete: geçmiş kaydı (upload/masraf/onay) olan kullanıcı FK'lar yüzünden
  // hard silinemez. deleted_at dolu = giriş kapalı, listede görünmez, tarihçe korunur.
  deleted_at DateTime?

  store_access    UserStoreAccess[]
  audit_logs      AuditLog[]
  manual_invoices ManualInvoice[]
  uploads               Upload[]      @relation("UploadedByUser")
  approved_days         DailyRecord[] @relation("ApprovedByUser")
  reconciled_days       DailyRecord[] @relation("ReconciliationNotesByUser")
  verifications         Verification[]
  cash_advances         CashAdvance[]
  expenses              Expense[]

  @@index([role])
}

model Brand {
  id         String    @id @default(uuid())
  name       String
  logo_url   String?
  created_at DateTime  @default(now())
  deleted_at DateTime?

  stores Store[]

  @@index([deleted_at])
}

model Store {
  id         String    @id @default(uuid())
  brand_id   String
  brand      Brand     @relation(fields: [brand_id], references: [id])
  name       String // "Lefkoşa", "Mağusa"
  city       String?
  address    String?
  created_at DateTime  @default(now())
  deleted_at DateTime?

  user_access     UserStoreAccess[]
  daily_records   DailyRecord[]
  budget_limits   BudgetLimit[]
  merge_groups    DayMergeGroup[]
  nebim_sale_lines NebimSaleLine[]
  outlet_stock_items OutletStockItem[]

  @@index([brand_id])
  @@index([deleted_at])
}

// Outlet reyonu fiziksel stok sayımı (barkod bazlı). Kullanıcı reyonu el
// terminaliyle okutur, barkod listesi buraya yüklenir. NebimSaleLine.barcode
// (köprüye eklenecek) ile eşleşince outlet tespiti fiyat-tahmininden kesin
// listeye döner. Aynı batch yeniden yüklenirse önce batch silinir (idempotent).
model OutletStockItem {
  id         String   @id @default(uuid())
  store_id   String
  store      Store    @relation(fields: [store_id], references: [id])
  barcode    String
  qty        Int      @default(1)
  scanned_at DateTime @db.Date
  batch      String // örn "lefkosa-sayim-2026-07-03"
  created_at DateTime @default(now())

  @@index([store_id, barcode])
  @@index([batch])
}

// ─────────────────────────────────────────────────────────────
// GÜN BİRLEŞMESİ (Derimod — birden fazla günün tek mağaza özetiyle uzlaşması)
// Örn. 19-20 Mayıs birleşik: her gün kendi POS/Z/nakit/masrafını tutar ama
// mağaza özeti tek olup tüm aralığı kapsar. Reconciliation günlerin toplamı
// ↔ tek özet karşılaştırır. Analytics yine gün-gün kalır.
// ─────────────────────────────────────────────────────────────

model DayMergeGroup {
  id         String   @id @default(uuid())
  store_id   String
  store      Store    @relation(fields: [store_id], references: [id])
  start_date DateTime @db.Date
  end_date   DateTime @db.Date
  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  daily_records DailyRecord[]

  @@unique([store_id, start_date, end_date])
  @@index([store_id])
}

model UserStoreAccess {
  user_id  String
  store_id String
  role     UserRole // Bu mağazadaki rolü
  user     User     @relation(fields: [user_id], references: [id])
  store    Store    @relation(fields: [store_id], references: [id])

  @@id([user_id, store_id])
  @@index([store_id])
}

// ─────────────────────────────────────────────────────────────
// GÜNLÜK KAYIT
// ─────────────────────────────────────────────────────────────

model DailyRecord {
  id               String            @id @default(uuid())
  store_id         String
  store            Store             @relation(fields: [store_id], references: [id])
  date             DateTime          @db.Date
  status           DailyRecordStatus @default(draft)
  approved_by      String?
  approved_by_user User?             @relation("ApprovedByUser", fields: [approved_by], references: [id])
  approved_at      DateTime?
  locked_at        DateTime?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  // Gün birleşmesi (Derimod) — bu gün bir birleşik gruba aitse dolu.
  // merge_index 1-tabanlı (1. gün, 2. gün, 3. gün). Mağaza özeti yalnızca
  // grubun SON gününe yüklenir, tüm aralığı kapsar.
  merge_group_id String?
  merge_group    DayMergeGroup? @relation(fields: [merge_group_id], references: [id])
  merge_index    Int?

  // KÜMÜLATİF KASA BİRLEŞMESİ (Mavi) — kasa kapatılmadığı için bu günün
  // mağaza özeti ÖNCEKİ günün satışlarını da içerir (kümülatif). Bu alan
  // önceki günün DailyRecord'una işaret eder. Gerçek bugün = bu özet −
  // önceki gün özeti (sales/cash/cc/loyalty). Derimod merge_group'tan ayrı.
  cumulative_prev_id String?
  cumulative_prev    DailyRecord?  @relation("CumulativeChain", fields: [cumulative_prev_id], references: [id])
  cumulative_next    DailyRecord[] @relation("CumulativeChain")

  // Müdür/admin'in gün sonu kasayı sayıp manuel girdiği nakit miktarı.
  // StoreSummary.cash_sales ile karşılaştırılır — eksik/fazla varsa uyarı
  // çıkar (kasa hırsızlığı tespiti).
  reported_cash_try  Decimal?  @db.Decimal(14, 2)
  reported_cash_note String?
  reported_cash_at   DateTime?

  // Hediye çeki — gün için manuel toplam (kullanıcı dosya yüklemez, sadece
  // miktar girer). Nakit denklemi: hediye + masraf + (sayım + dekont) =
  // StoreSummary.cash_sales. Hiç girilmediyse 0 sayılır (alınmamış demek).
  gift_voucher_try  Decimal?  @db.Decimal(14, 2)
  gift_voucher_note String?
  gift_voucher_at   DateTime?

  // MAVI HEDİYE ÇEKİ — sadece Derimod mağazalarında girilir.
  // Mavi'de yüksek alışveriş yapan müşterilere verilen, Derimod'da kullanılan
  // hediye çekleri. KASA İLE ALAKASI YOKTUR — nakit denklemine girmez.
  // Sadece istatistik/bilgi amaçlı (gün başına manuel toplam tutar).
  mavi_gift_voucher_try  Decimal?  @db.Decimal(14, 2)
  mavi_gift_voucher_note String?
  mavi_gift_voucher_at   DateTime?

  // Mutabakat farkı için açıklayıcı not (müdür ya da admin).
  // Örn. "müşteri 500 TL fazla nakit verdi, üstü unutulmuş";
  //      "POS terminali geri ödeme yaptı, raporlanmadı".
  reconciliation_notes      String?
  reconciliation_notes_at   DateTime?
  reconciliation_notes_by   String?
  reconciliation_notes_user User?     @relation("ReconciliationNotesByUser", fields: [reconciliation_notes_by], references: [id])

  uploads             Upload[]
  pos_slips           PosSlip[]
  store_summary       StoreSummary? // 1:1 (her gün 1 özet)
  dealer_daily_report DealerDailyReport? // 1:1 (her gün 1 SAP bayi raporu)
  bank_receipts       BankReceipt[]
  expenses            Expense[]
  cash_advances       CashAdvance[]
  corporate_purchases CorporatePurchase[]
  z_reports           ZReport[]
  manual_invoices     ManualInvoice[]
  verification        Verification? // 1:1

  @@unique([store_id, date])
  @@index([date])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// UPLOADS (Generic)
// ─────────────────────────────────────────────────────────────

model Upload {
  id               String       @id @default(uuid())
  daily_record_id  String
  daily_record     DailyRecord  @relation(fields: [daily_record_id], references: [id])
  type             UploadType
  file_url         String // Supabase Storage path
  file_hash        String? // SHA-256 of original buffer (duplicate detection)
  mime_type        String
  file_size_bytes  Int
  uploaded_by      String
  uploaded_by_user User         @relation("UploadedByUser", fields: [uploaded_by], references: [id])
  uploaded_at      DateTime     @default(now())
  raw_ocr_json     Json? // Claude'un ham çıktısı
  parsed_data_json Json? // Zod ile validate edilmiş hali
  // Kullanıcının yükleme anında girdiği meta bilgiler — OCR sonucunu
  // override eder. Örn expense için {category, description}.
  user_meta_json   Json?
  status           UploadStatus @default(pending)
  error_message    String? // OCR fail olursa
  date_mismatch    Boolean      @default(false) // slip_date != daily_record.date
  duplicate_of_id  String? // Bu upload bir başkasının kopyası ise FK

  pos_slip            PosSlip?
  store_summary       StoreSummary?
  bank_receipt        BankReceipt?
  expense             Expense?
  z_report            ZReport?
  dealer_daily_report DealerDailyReport?

  @@index([daily_record_id])
  @@index([type])
  @@index([status])
  @@index([daily_record_id, file_hash])
}

// ─────────────────────────────────────────────────────────────
// PARSED ENTITIES (OCR sonrası normalize)
// ─────────────────────────────────────────────────────────────

model PosSlip {
  id              String      @id @default(uuid())
  upload_id       String      @unique
  upload          Upload      @relation(fields: [upload_id], references: [id], onDelete: Cascade)
  daily_record_id String
  daily_record    DailyRecord @relation(fields: [daily_record_id], references: [id])

  bank_name      String? // İş Bankası, Ziraat, Koopbank vb.
  terminal_no    String?
  slip_date      DateTime? @db.Date
  sales_count    Int?
  sales_amount   Decimal?  @db.Decimal(14, 2)
  refund_count   Int?
  refund_amount  Decimal?  @db.Decimal(14, 2)
  net_amount     Decimal?  @db.Decimal(14, 2)
  currency       Currency  @default(TRY)
  net_amount_try Decimal?  @db.Decimal(14, 2) // TRY karşılığı
  fx_rate_used   Decimal?  @db.Decimal(10, 4)

  // SHA-256 of (bank_name|terminal_no|slip_date|net_amount|sales_count) —
  // catches "same slip uploaded as a different photo" replay attempts.
  content_fingerprint String?

  user_corrected Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([daily_record_id])
  @@index([bank_name])
  @@index([daily_record_id, content_fingerprint])
}

model StoreSummary {
  id              String      @id @default(uuid())
  upload_id       String      @unique
  upload          Upload      @relation(fields: [upload_id], references: [id], onDelete: Cascade)
  daily_record_id String      @unique // 1:1 — her gün 1 özet
  daily_record    DailyRecord @relation(fields: [daily_record_id], references: [id])

  sales_total          Decimal? @db.Decimal(14, 2)
  cash_sales           Decimal? @db.Decimal(14, 2)
  credit_card_total    Decimal? @db.Decimal(14, 2)
  loyalty_points_total Decimal? @db.Decimal(14, 2) // Kartuş Puan
  // Alışveriş Çeki Toplam — Mavi HQ (Türkiye) tarafından iade edilen çekler.
  // Satış toplamına dahil bir ödeme kalemi; iade takibi için ayrı saklanır.
  shopping_voucher_total Decimal? @db.Decimal(14, 2)
  // Havale (Banka Transferi) — özette ayrı kalem varsa dolu. Yoksa null/0
  // sayılır ve nakit dekontu cash_sales içine işlenmiş varsayılır.
  wire_transfer_total  Decimal? @db.Decimal(14, 2)
  opening_balance      Decimal? @db.Decimal(14, 2)
  closing_balance      Decimal? @db.Decimal(14, 2)
  currency             Currency @default(TRY)

  // Özetin kapsadığı tarih aralığı (Derimod gün birleşmesi). Tek gün ise
  // period_start = period_end = o gün. Birleşik ise aralık (örn 19-20 May).
  // OCR Derimod özetinin altındaki tarih aralığından okur.
  period_start DateTime? @db.Date
  period_end   DateTime? @db.Date

  // TRY çevrilmiş halleri (raporlama için)
  sales_total_try          Decimal? @db.Decimal(14, 2)
  cash_sales_try           Decimal? @db.Decimal(14, 2)
  credit_card_total_try    Decimal? @db.Decimal(14, 2)
  loyalty_points_total_try Decimal? @db.Decimal(14, 2)
  shopping_voucher_total_try Decimal? @db.Decimal(14, 2)
  wire_transfer_total_try  Decimal? @db.Decimal(14, 2)
  fx_rate_used             Decimal? @db.Decimal(10, 4)

  user_corrected Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

model BankReceipt {
  id              String      @id @default(uuid())
  upload_id       String?     @unique // Manuel girişlerde null
  upload          Upload?     @relation(fields: [upload_id], references: [id], onDelete: Cascade)
  daily_record_id String
  daily_record    DailyRecord @relation(fields: [daily_record_id], references: [id])

  bank_id      String?
  bank         Bank?    @relation(fields: [bank_id], references: [id])
  bank_name    String? // OCR'dan ham
  iban         String?
  amount       Decimal  @db.Decimal(14, 2)
  currency     Currency @default(TRY)
  amount_try   Decimal  @db.Decimal(14, 2)
  fx_rate_used Decimal? @db.Decimal(10, 4)
  deposit_date DateTime @db.Date
  is_manual    Boolean  @default(false) // Dekont yoksa admin manuel girer

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([daily_record_id])
}

model Expense {
  id              String      @id @default(uuid())
  upload_id       String?     @unique
  upload          Upload?     @relation(fields: [upload_id], references: [id], onDelete: Cascade)
  daily_record_id String
  daily_record    DailyRecord @relation(fields: [daily_record_id], references: [id])

  category     ExpenseCategory
  vendor       String?
  amount       Decimal         @db.Decimal(14, 2)
  currency     Currency        @default(TRY)
  amount_try   Decimal         @db.Decimal(14, 2)
  fx_rate_used Decimal?        @db.Decimal(10, 4)
  expense_date DateTime        @db.Date
  description  String?
  employee_id  String?
  employee     User?           @relation(fields: [employee_id], references: [id])
  vat_rate     Decimal?        @db.Decimal(5, 2)
  vat_included Boolean         @default(true)

  user_corrected Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([daily_record_id])
  @@index([category])
}

enum StaffRole {
  manager // Müdür
  assistant_manager // Müdür Yardımcısı
  sales_staff // Satış Elemanı
}

model CashAdvance {
  id              String      @id @default(uuid())
  daily_record_id String
  daily_record    DailyRecord @relation(fields: [daily_record_id], references: [id])
  // Çalışan opsiyonel — peşin ödeme belirli bir çalışana bağlı olmayabilir
  employee_id     String?
  employee        User?       @relation(fields: [employee_id], references: [id])

  // AVANS takibi (category=bonus iken): personelin rolü + isim soyisim.
  // Maaştan kesinti için: aylık, kişi bazlı tarihli döküm /tr/advances'te.
  staff_role StaffRole?
  staff_name String?

  amount       Decimal         @db.Decimal(14, 2)
  currency     Currency        @default(TRY)
  amount_try   Decimal         @db.Decimal(14, 2)
  fx_rate_used Decimal?        @db.Decimal(10, 4)
  category     ExpenseCategory
  description  String?
  receipt_url  String? // Opsiyonel fiş

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([daily_record_id])
  @@index([employee_id])
}

// ─────────────────────────────────────────────────────────────
// KURUMSAL & YÖNETİM ALIŞVERİŞİ
// ─────────────────────────────────────────────────────────────
//
// Kurumsal firmalar (Kaner, Tip-İş, Orhan Şevketler...) ve yöneticiler/kişiler
// fiziksel ödeme YAPMADAN ürün alır (cari / borç / sonradan ödeme). Satış
// sisteme işlendiği için satış raporu (StoreSummary.sales_total) yükselir ama
// kasaya nakit/kart girmez → gün sonunda kasa eksik görünür (yanlış kayıp
// sinyali). Bu kayıtlar girilince tutar GENEL TOPLAM'ın belge/ödeme tarafına
// eklenir (compute.ts) → kasa tutar.
//
// Ayrıca borç takibi: kişi/şirket bazında toplam alışveriş + ödenen + kalan
// borç /tr/corporate analiz sayfasında gösterilir.

enum CorporatePurchaseType {
  corporate // Kurumsal (anlaşmalı şirket — Kaner, Tip-İş...)
  management // Yönetim (yönetici/kişi)
}

model CorporatePurchase {
  id              String      @id @default(uuid())
  daily_record_id String
  daily_record    DailyRecord @relation(fields: [daily_record_id], references: [id])

  type CorporatePurchaseType

  // Kurumsal için şirket adı (opsiyonel — boşsa kişi bazında gruplanır).
  // Yönetim için genelde null.
  company_name String?
  // İsim soyisim — HER ZAMAN zorunlu (kim aldı).
  person_name  String

  amount       Decimal  @db.Decimal(14, 2)
  currency     Currency @default(TRY)
  amount_try   Decimal  @db.Decimal(14, 2)
  fx_rate_used Decimal? @db.Decimal(10, 4)

  // Borç kapandı mı? false = borç (ödenmemiş), true = ödendi.
  // Reconciliation'ı ETKİLEMEZ (fiziksel para o gün girmediği için kayıt her
  // hâlükârda kasa toplamına eklenir); sadece borç takibi/analiz içindir.
  is_paid Boolean @default(false)
  note    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([daily_record_id])
  @@index([type])
}

// ─────────────────────────────────────────────────────────────
// BUDGET LIMITS (gider limit takibi + alert)
// ─────────────────────────────────────────────────────────────

model BudgetLimit {
  id    String  @id @default(uuid())
  name  String? // Opsiyonel açıklayıcı isim ("Lefkoşa kira limiti" vs.)

  // null = tüm mağazalar için global limit
  store_id String?
  store    Store?  @relation(fields: [store_id], references: [id])

  scope    BudgetScope
  category ExpenseCategory? // scope=category ise dolu olmalı

  mode       BudgetMode
  amount_try Decimal?   @db.Decimal(14, 2) // mode=amount ise (TRY)
  ratio_pct  Decimal?   @db.Decimal(5, 2) // mode=ratio ise (örn 15 = %15)

  period       BudgetPeriod
  period_start DateTime?    @db.Date // period=custom ise
  period_end   DateTime?    @db.Date // period=custom ise

  alert_pct Decimal @default(80) @db.Decimal(5, 2) // %80'e ulaşınca erken uyarı

  is_active  Boolean   @default(true)
  notes      String?
  created_by String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@index([store_id])
  @@index([is_active])
}

// ─────────────────────────────────────────────────────────────
// VERIFICATION
// ─────────────────────────────────────────────────────────────

model Verification {
  id               String             @id @default(uuid())
  daily_record_id  String             @unique
  daily_record     DailyRecord        @relation(fields: [daily_record_id], references: [id])
  expected_total   Decimal            @db.Decimal(14, 2) // Σ(POS) + Nakit + Kartuş
  actual_total     Decimal            @db.Decimal(14, 2) // Mağaza Raporu sales_total
  difference       Decimal            @db.Decimal(14, 2)
  status           VerificationStatus
  notes            String?
  verified_by      String?
  verified_by_user User?              @relation(fields: [verified_by], references: [id])
  verified_at      DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// REFERANS TABLOLARI
// ─────────────────────────────────────────────────────────────

model Bank {
  id                      String   @id @default(uuid())
  name                    String   @unique // İş Bankası, Ziraat, Koopbank, Maximum, TEB...
  commission_rate_default Decimal? @db.Decimal(5, 4) // Örn 0.0150 = %1.50
  is_active               Boolean  @default(true)

  bank_receipts BankReceipt[]

  @@index([is_active])
}

model FxRate {
  date        DateTime @db.Date
  currency    Currency
  rate_to_try Decimal  @db.Decimal(10, 4)
  source      String   @default("TCMB")
  fetched_at  DateTime @default(now())

  @@id([date, currency])
  @@index([currency])
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?
  user        User?    @relation(fields: [user_id], references: [id])
  action      String // 'create' | 'update' | 'delete' | 'approve' | 'lock' | 'unlock'
  entity_type String // 'PosSlip', 'DailyRecord', etc.
  entity_id   String?
  before_json Json?
  after_json  Json?
  ip_address  String?
  created_at  DateTime @default(now())

  @@index([user_id])
  @@index([entity_type, entity_id])
  @@index([created_at])
}

// ─────────────────────────────────────────────────────────────
// Z REPORT (yazar kasa gün sonu kapanış raporu) + EL FATURASI
// ─────────────────────────────────────────────────────────────

model ZReport {
  id              String      @id @default(uuid())
  upload_id       String      @unique
  upload          Upload      @relation(fields: [upload_id], references: [id], onDelete: Cascade)
  daily_record_id String
  daily_record    DailyRecord @relation(fields: [daily_record_id], references: [id])

  report_no         String?
  report_date       DateTime? @db.Date
  gross_sales       Decimal?  @db.Decimal(14, 2) // Brüt satış
  net_sales         Decimal?  @db.Decimal(14, 2) // Net satış
  cash_sales        Decimal?  @db.Decimal(14, 2) // Nakit satış
  credit_card_sales Decimal?  @db.Decimal(14, 2) // Kredi kartı satış
  refund_amount     Decimal?  @db.Decimal(14, 2)
  vat_total         Decimal?  @db.Decimal(14, 2)
  currency          Currency  @default(TRY)

  // TRY çevrimleri
  gross_sales_try       Decimal? @db.Decimal(14, 2)
  net_sales_try         Decimal? @db.Decimal(14, 2)
  cash_sales_try        Decimal? @db.Decimal(14, 2)
  credit_card_sales_try Decimal? @db.Decimal(14, 2)

  // SHA-256(report_no|report_date|net_sales|credit_card_sales) — replay guard
  content_fingerprint String?

  user_corrected Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([daily_record_id])
  @@index([daily_record_id, content_fingerprint])
}

// ─────────────────────────────────────────────────────────────
// DEALER DAILY REPORT (Mavi SAP / Derimod Nebim — bayi gün sonu raporu)
// Ham kaynak veri — müdür özet rakamlarını manipüle edemez. Reconciliation'da
// "doğru kaynak" olarak gösterilir.
// ─────────────────────────────────────────────────────────────

model DealerDailyReport {
  id              String      @id @default(uuid())
  upload_id       String      @unique
  upload          Upload      @relation(fields: [upload_id], references: [id], onDelete: Cascade)
  daily_record_id String      @unique // 1:1 — her gün için tek bayi raporu
  daily_record    DailyRecord @relation(fields: [daily_record_id], references: [id])

  // Kaynak sistem ("sap" — Mavi, "nebim" — Derimod gelecekte)
  source String @default("sap")

  // Mağaza kodu (örn 9402 = Mavi Mağusa). UI'da çapraz kontrol için.
  store_code  String?
  report_date DateTime @db.Date

  // ── ANA ALANLAR ─────────
  // Tüm satırların Net Tutar toplamı (iadelerle nette)
  net_sales_try Decimal @db.Decimal(14, 2)
  // Tüm satırların Kartuş Kart toplamı (sadakat puanı kullanımı, TL)
  loyalty_try Decimal @db.Decimal(14, 2)
  // Tüm satırların Hediye Kart toplamı
  gift_card_try Decimal? @db.Decimal(14, 2)

  // ── METADATA ─────────
  transaction_count Int // Benzersiz fiş sayısı
  line_count        Int // Toplam satır (ürün) sayısı
  refund_count      Int // İade satırı sayısı
  // Dosya kapsam aralığı (1+ gün olabilir; sadece seçili güne filtre uygulanır)
  source_date_min DateTime? @db.Date
  source_date_max DateTime? @db.Date

  // Replay guard: SHA-256(store_code|report_date|net_sales|transaction_count)
  content_fingerprint String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([daily_record_id])
  @@index([report_date])
}

model ManualInvoice {
  id              String      @id @default(uuid())
  daily_record_id String
  daily_record    DailyRecord @relation(fields: [daily_record_id], references: [id])

  amount       Decimal  @db.Decimal(14, 2)
  currency     Currency @default(TRY)
  amount_try   Decimal  @db.Decimal(14, 2)
  fx_rate_used Decimal? @db.Decimal(10, 4)

  invoice_no   String?
  invoice_date DateTime? @db.Date
  description  String?

  created_by      String
  created_by_user User     @relation(fields: [created_by], references: [id])
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([daily_record_id])
}

// ─────────────────────────────────────────────────────────────
// NEBIM PERAKENDE SATIŞ (Derimod — satır satır ham satış)
// NEBIM V3 SQL'den günlük API köprüsüyle aktarılır (dosya yükleme DEĞİL).
// Her satır = bir fişin bir ürün satırı. (company_code, invoice_ref,
// sort_order) benzersiz → köprü son N günü tekrar gönderse de çiftlemez.
// DealerDailyReport (gün-özet) ile ilişkisiz; ham/granül kaynak.
// ─────────────────────────────────────────────────────────────

model NebimSaleLine {
  id String @id @default(uuid())

  // Kaynak kimliği (idempotent upsert anahtarı)
  company_code Int // NEBIM şirket kodu (Derimod = 1)
  invoice_ref  String // Fatura ref no, örn "1-R-7-87640"
  sort_order   Int // Fiş içi satır sırası

  // Mağaza — NEBIM adından Derimod mağazasına eşlenir (eşleşmezse null kalır)
  store_id         String?
  store            Store?  @relation(fields: [store_id], references: [id])
  nebim_store_code String? // Ham NEBIM mağaza kodu (S01/S02/S03)
  store_name_raw   String? // NEBIM mağaza adı, örn "Girne Mağaza"

  invoice_date DateTime  @db.Date
  created_date DateTime?
  is_return    Boolean   @default(false)
  office       String?

  // Ürün
  item_code  String?
  item_desc  String?
  color_code String?
  color_desc String?
  size       String?

  salesperson_code String?
  salesperson_name String?

  // Müşteri — trInvoiceHeader.CurrAccCode → cdCurrAcc (isimli/sadık müşteride dolu;
  // anonim perakendede boş)
  customer_code String?
  customer_name String?

  // Ödeme tipi — trPaymentHeader(DocumentNumber=InvoiceNumber) → trPaymentLine.PaymentTypeCode
  // payment_type: "Nakit" / "Kredi Kartı" / "Nakit + Kredi Kartı" (fatura geneli)
  // card_type: kart markası (Maksimum, Garanti Bonus…) — kredi kartı ödemelerinde
  payment_type String?
  card_type    String?

  // Fatura-bazlı ödeme tutarları (her satırda tekrar — fatura geneli; gün
  // kıyası için invoice_ref ile tekilleştir). trPaymentLine → trCashLine /
  // trCreditCardPaymentLine .CurrAccAmount.
  pay_cash Decimal? @db.Decimal(14, 2) // Nakit ödenen (PaymentTypeCode=1)
  pay_card Decimal? @db.Decimal(14, 2) // Kredi kartı ödenen (PaymentTypeCode=2)

  // Tutarlar (D = yerel para / TRY)
  qty        Decimal  @db.Decimal(14, 3)
  price      Decimal? @db.Decimal(14, 2)
  vat_rate   Decimal? @db.Decimal(5, 2)
  amount_vi  Decimal? @db.Decimal(14, 2) // Tutar (VD)(D)
  line_disc  Decimal? @db.Decimal(14, 2) // Toplam satır iskonto
  doc_disc   Decimal? @db.Decimal(14, 2) // Toplam dip iskonto
  tax_base   Decimal? @db.Decimal(14, 2) // Vergi hariç tutar (KDV matrahı)
  vat        Decimal? @db.Decimal(14, 2) // KDV
  net_amount Decimal? @db.Decimal(14, 2) // Net tutar (KDV dahil)

  // İndirim oranı (%), ingest'te hesaplanır: (amount_vi - net_amount)/amount_vi*100.
  // Sadece satış (iade hariç, amount_vi>0) için; aksi null. Filtre/sıralama için.
  discount_pct Decimal? @db.Decimal(6, 2)

  // İndirim/kampanya metası (Phase 2 — fatura/satır seviyesi)
  invoice_note    String? // trInvoiceHeader.Description — FİŞ açıklaması (kasiyer notu)
  mgmt_note       String? // tpInvoiceHeaderExtension.DiscountReasonDescription — YÖNETİM açıklaması (şifreli manuel iskonto notu)
  discount_reason String? // cdDiscountReasonDesc — iskonto nedeni ("Yönetim Özel talebi")
  campaign        String? // tpInvoiceDiscountOffer → cdDiscountOfferDesc — satıra uygulanan kampanya adı/adları

  currency Currency @default(TRY)

  source     String   @default("nebim")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([company_code, invoice_ref, sort_order])
  @@index([store_id])
  @@index([invoice_date])
  @@index([store_name_raw, invoice_date])
}

// ─────────────────────────────────────────────────────────────
// FATURALI MASRAF (şirket kartı) — aylık yükleme + kategorize + dağıtım
// ─────────────────────────────────────────────────────────────
// Kullanıcı her ay "Faturalı Masraflar" Excel'ini yükler. Sistem kategorize
// eder, $/£/€ tutarları KKTCMB satış kuruyla TL'ye çevirir. Sonra dağıtım
// motoru kategoride aylık toplar → ÷7 → 7 mağazaya eşit dağıtır.
// Detay: docs/MASRAF-MUHASEBE-PLANI.md

model InvoicedExpenseBatch {
  id              String    @id @default(uuid())
  period_year     Int
  period_month    Int // 1-12 — yüklemenin ait olduğu ay
  source_filename String?
  status          String    @default("draft") // draft | confirmed
  uploaded_by     String // User.id (audit; FK değil)
  created_at      DateTime  @default(now())
  confirmed_at    DateTime?

  items InvoicedExpenseItem[]

  @@index([period_year, period_month])
  @@index([status])
}

model InvoicedExpenseItem {
  id       String               @id @default(uuid())
  batch_id String
  batch    InvoicedExpenseBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  expense_date    DateTime @db.Date
  raw_description String

  amount_original Decimal   @db.Decimal(14, 2)
  currency        Currency  @default(TRY)
  fx_rate         Decimal?  @db.Decimal(14, 5) // KKTCMB satış kuru (yabancı para ise)
  fx_rate_date    DateTime? @db.Date // kurun alındığı gerçek tarih (hafta sonu fallback)
  amount_try      Decimal   @db.Decimal(14, 2)

  // Kategorize sonucu
  category      String // MasrafKategori key (ISCI/YEMEK/TERZI/KIRTASIYE/MARKET/MAZOT/SEYAHAT/KIRA/DIGER/IGNORE)
  auto_category String // sistemin ilk önerisi (audit — kullanıcı değiştirdiyse fark görünür)
  needs_review  Boolean @default(false) // DİĞER'e düşen belirsizler
  // KİRA için: ait olduğu ay (açıklamadan parse; ödeme ayından farklı olabilir)
  belongs_month Int?
  note          String?

  @@index([batch_id])
  @@index([category])
}

// ─────────────────────────────────────────────────────────────
// DEFOLU — İndirim Kontrol programından push (ay × Mavi mağaza zarar toplamı)
// ─────────────────────────────────────────────────────────────
// mavi-iskonto-sistemi → POST /api/ingest/defolu (Bearer INGEST_API_TOKEN).
// Masraf matrisinde "DEFOLU" kategori satırını Mavi kodu bazlı doldurur.
// Idempotent: (year, month, store_code) tekrar gelirse tutar güncellenir.
// Detay: docs/MASRAF-MUHASEBE-PLANI.md (Faz 5)

model DefoluEntry {
  id           String   @id @default(uuid())
  period_year  Int
  period_month Int // 1-12
  store_code   String // Mavi kodu: 9400 Lefkoşa / 9401 Girne / 9402 Mağusa / 9403 Güzelyurt
  amount_try   Decimal  @db.Decimal(14, 2) // ay×mağaza defolu zarar toplamı (TL)
  source       String   @default("indirim-kontrol")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([period_year, period_month, store_code])
  @@index([period_year])
}
